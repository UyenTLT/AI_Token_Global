  .toc-link:hover { background-color: #F5F2FF; color: #6155F1; }
  .toc-link.active { background-color: #E2DFFE; color: #6155F1; font-weight: 600; }
  .toc-link:focus-visible { outline: 2px solid #6155F1; outline-offset: 2px; }

