  .ug-callout p { font-size: 0.875rem; line-height: 1.7; color: #3C315B; margin: 0; }
  .ug-callout strong { color: #3C315B; font-weight: 700; }
  .ug-faq-answer-body p { font-size: 0.9rem; line-height: 1.75; color: #555; margin: 0; padding-bottom: 1.25rem; }
  .ug-problems-callout .problems-intro p { font-size: 0.875rem; font-weight: 600; color: #3C315B; line-height: 1.6; margin: 0 0 1rem 0; }

