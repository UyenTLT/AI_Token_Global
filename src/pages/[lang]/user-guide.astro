    display: block;
    padding: 0.5rem 0.875rem;
    border-radius: 8px;
    font-size: 0.855rem;
    font-weight: 500;
    color: #555;
    text-decoration: none;
    transition: background-color 0.15s ease, color 0.15s ease;
    line-height: 1.4;
