<script is:inline>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
  }, { threshold: 0.06 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

  window.toggleFaq = function(btn) {
    var answer = btn.nextElementSibling;
    var chevron = btn.querySelector('.faq-chevron');
    var isOpen = answer.classList.contains('open');
    document.querySelectorAll('.faq-answer').forEach(function(a) { a.classList.remove('open'); });
    document.querySelectorAll('.faq-chevron').forEach(function(c) { c.classList.remove('open'); });
    if (!isOpen) {
      answer.classList.add('open');
      if (chevron) chevron.classList.add('open');
    }
  };

  // Active TOC highlight on scroll
  (function() {
    var tocLinks = document.querySelectorAll('.toc-link[data-toc-target]');
    if (!tocLinks.length) return;
    function updateToc() {
      var current = tocLinks[0].getAttribute('data-toc-target');
      tocLinks.forEach(function(link) {
        var id = link.getAttribute('data-toc-target');
        var el = document.getElementById(id);
        if (el && el.getBoundingClientRect().top < 120) current = id;
      });
      tocLinks.forEach(function(l) {
        if (l.getAttribute('data-toc-target') === current) l.classList.add('active');
        else l.classList.remove('active');
      });
    }
    window.addEventListener('scroll', updateToc, { passive: true });
    updateToc();
  })();
</script>
