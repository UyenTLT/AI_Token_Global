---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/index';
import type { Lang } from '../i18n/index';
import type { ApiModelPageData } from '../lib/sanity';
import { toHTML } from '@portabletext/to-html';

export interface Props {
  page: ApiModelPageData;
  lang: Lang;
  modelSlug: 'chatgpt' | 'claude' | 'gemini';
}

const { page, lang, modelSlug } = Astro.props;
const t = useTranslations(lang);

function pt(blocks: any[] | undefined): string {
  if (!blocks?.length) return '';
  return toHTML(blocks, {
    components: {
      marks: {
        strong: ({ children }) => `<strong>${children}</strong>`,
        em:     ({ children }) => `<em>${children}</em>`,
        link:   ({ value, children }) => `<a href="${value?.href ?? '#'}" target="${value?.href?.startsWith('http') ? '_blank' : '_self'}" rel="noopener noreferrer">${children}</a>`,
      },
    },
  });
}

// Per-model hero gradient: outer section overlay + inner solid card
const HERO = {
  chatgpt: {
    sectionBg: 'linear-gradient(135deg,rgba(97,85,241,.08) 0%,rgba(62,129,229,.06) 100%),#F5F2FF',
    cardBg:    'linear-gradient(135deg,#6155F1 0%,#3E81E5 100%)',
  },
  claude: {
    sectionBg: 'linear-gradient(135deg,rgba(45,134,83,.08) 0%,rgba(97,85,241,.06) 100%),#F5F2FF',
    cardBg:    'linear-gradient(135deg,#2D8653 0%,#3E81E5 100%)',
  },
  gemini: {
    sectionBg: 'linear-gradient(135deg,rgba(62,129,229,.1) 0%,rgba(97,85,241,.06) 100%),#F5F2FF',
    cardBg:    'linear-gradient(135deg,#3E81E5 0%,#6155F1 100%)',
  },
} as const;
const hero = HERO[modelSlug];

// "Also Compare" — link colors per source page (matches archive)
const ALSO_COMPARE_COLOR: Record<string, Record<string, string>> = {
  chatgpt: { claude: '#6155F1', gemini: '#3E81E5' },
  claude:  { chatgpt: '#6155F1', gemini: '#3E81E5' },
  gemini:  { chatgpt: '#6155F1', claude: '#2D8653' },
};

const ALL_MODELS = [
  { slug: 'chatgpt', shortKey: 'chatgptApiShort', guideKey: 'chatgptApiGuide', path: `/${lang}/chatgpt-api` },
  { slug: 'claude',  shortKey: 'claudeApiShort',  guideKey: 'claudeApiGuide',  path: `/${lang}/claude-api`  },
  { slug: 'gemini',  shortKey: 'geminiApiShort',  guideKey: 'geminiApiGuide',  path: `/${lang}/gemini-api`  },
] as const;
const alsoCompare = ALL_MODELS.filter(m => m.slug !== modelSlug);

const breadcrumbCurrent = t(`apiModel.${ALL_MODELS.find(m => m.slug === modelSlug)!.shortKey}`);

const seoTitle = page.seo?.seoTitle ?? page.heroHeadline;
const seoDesc  = page.seo?.seoDescription ?? page.heroSubtitle ?? '';
---

<BaseLayout
  title={`${seoTitle} — AI Token King`}
  description={seoDesc}
  activePage="api-compare"
  lang={lang}
  seo={page.seo}
>

  <!-- HERO ──────────────────────────────────────────────── -->
  <section style={`background:${hero.sectionBg};padding:3rem 1.5rem 2.5rem;`}>
    <div style="max-width:1200px;margin:0 auto;">
      <!-- Breadcrumb -->
      <nav style="display:flex;align-items:center;gap:.5rem;margin-bottom:1.75rem;font-size:.8rem;color:#999;flex-wrap:wrap;" aria-label={t('common.aria.breadcrumb')}>
        <a href={`/${lang}/`} style="color:#999;text-decoration:none;transition:color .15s ease;" onmouseover="this.style.color='#6155F1'" onmouseout="this.style.color='#999'">{t('common.home')}</a>
        <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="#CCC" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <a href={`/${lang}/api-compare`} style="color:#999;text-decoration:none;transition:color .15s ease;" onmouseover="this.style.color='#6155F1'" onmouseout="this.style.color='#999'">{t('nav.compareModels')}</a>
        <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="#CCC" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span style="color:#6155F1;font-weight:600;">{breadcrumbCurrent}</span>
      </nav>

      <!-- Inner gradient card with title + subtitle -->
      <div style={`background:${hero.cardBg};border-radius:16px;padding:2rem 2.5rem;margin-bottom:2rem;`}>
        <h1 class="fade-up" style="font-family:'Kanit',sans-serif;font-size:clamp(1.5rem,3vw,2rem);font-weight:800;color:#fff;letter-spacing:-.03em;margin-bottom:.5rem;">
          {page.heroHeadline}
        </h1>
        {page.heroSubtitle && (
          <p class="fade-up fade-up-1" style="font-size:.925rem;color:rgba(255,255,255,.85);line-height:1.7;max-width:580px;">
            {page.heroSubtitle}
          </p>
        )}
      </div>
    </div>
  </section>

  <!-- MAIN LAYOUT ────────────────────────────────────────── -->
  <section style="padding:2.5rem 1.5rem 5rem;">
    <div class="post-layout" style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 280px;gap:3rem;align-items:start;">

      <!-- ── Article body ────────────────────────────────── -->
      <article class="article-body">

        <!-- Overview -->
        <h2 id="overview">{page.heroHeadline}</h2>
        {page.overviewBody && page.overviewBody.length > 0 && (
          <div class="reveal" set:html={pt(page.overviewBody)} />
        )}

        <!-- What Is -->
        {page.whatIsTitle && (
          <Fragment>
            <h2 id="what-is">{page.whatIsTitle}</h2>
            {page.whatIsBody && <div class="reveal" set:html={pt(page.whatIsBody)} />}
          </Fragment>
        )}

        <!-- Use Cases -->
        {page.useCasesTitle && (
          <Fragment>
            <h2 id="use-cases">{page.useCasesTitle}</h2>
            {page.useCasesBody && <div class="reveal" set:html={pt(page.useCasesBody)} />}
          </Fragment>
        )}

        <!-- Pricing -->
        {page.pricingTitle && (
          <Fragment>
            <h2 id="pricing">{page.pricingTitle}</h2>
            {page.pricingBody && <div class="reveal" set:html={pt(page.pricingBody)} />}

            {page.pricingReference && page.pricingReference.length > 0 && (
              <Fragment>
                <h3 id="pricing-reference">{t('apiModel.pricingReferenceLabel')}</h3>
                <div class="reveal" set:html={pt(page.pricingReference)} />
              </Fragment>
            )}
          </Fragment>
        )}

        <!-- Unique section (e.g., "Who It's For") -->
        {page.uniqueSectionTitle && (
          <Fragment>
            <h2 id="unique-section">{page.uniqueSectionTitle}</h2>
            {page.uniqueSectionBody && <div class="reveal" set:html={pt(page.uniqueSectionBody)} />}
          </Fragment>
        )}

        <!-- Comparing -->
        {page.comparingTitle && (
          <Fragment>
            <h2 id="comparing">{page.comparingTitle}</h2>
            {page.comparingBody && <div class="reveal" set:html={pt(page.comparingBody)} />}
          </Fragment>
        )}

        <!-- Further Reading -->
        {page.furtherReading && page.furtherReading.length > 0 && (
          <Fragment>
            <h2 id="further-reading">{page.furtherReadingTitle ?? t('apiModel.furtherReadingFallback')}</h2>
            <ul>
              {page.furtherReading.map(link => (
                <li>
                  <a
                    href={link.url ?? '#'}
                    target={link.url?.startsWith('http') ? '_blank' : '_self'}
                    rel="noopener noreferrer">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </Fragment>
        )}

        <!-- FAQ -->
        {page.faq && page.faq.length > 0 && (
          <Fragment>
            <h2 id="faq">{page.faqTitle ?? t('apiModel.faqFallback')}</h2>
            <div class="faq-wrap">
              {page.faq.map((item, idx) => (
                <div class={`faq-row${idx === (page.faq!.length - 1) ? ' is-last' : ''}`}>
                  <button class="faq-q" onclick="window.toggleFaq(this)" type="button">
                    <span>{item.question}</span>
                    <svg class="faq-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="#6155F1" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                  <div class="faq-answer">
                    <div class="faq-answer-body" set:html={pt(item.answer)} />
                  </div>
                </div>
              ))}
            </div>
          </Fragment>
        )}

      </article>

      <!-- ── Sidebar ──────────────────────────────────────── -->
      <aside class="post-sidebar">

        <!-- On This Page TOC -->
        <div class="sidebar-card">
          <div class="sidebar-card-title">{t('common.onThisPage')}</div>
          <nav style="display:flex;flex-direction:column;gap:.125rem;" id="toc-nav">
            <a href="#overview" class="sidebar-link active">{t('apiModel.tocOverview')}</a>
            {page.whatIsTitle && <a href="#what-is" class="sidebar-link">{page.whatIsTitle}</a>}
            {page.useCasesTitle && <a href="#use-cases" class="sidebar-link">{page.useCasesTitle}</a>}
            {page.pricingTitle && <a href="#pricing" class="sidebar-link">{page.pricingTitle}</a>}
            {page.uniqueSectionTitle && <a href="#unique-section" class="sidebar-link">{page.uniqueSectionTitle}</a>}
            {page.comparingTitle && <a href="#comparing" class="sidebar-link">{page.comparingTitle}</a>}
            {(page.faq?.length ?? 0) > 0 && <a href="#faq" class="sidebar-link">{page.faqTitle ?? t('apiModel.faqFallback')}</a>}
          </nav>
        </div>

        <!-- Compare All Models CTA -->
        <div class="sidebar-cta" style={`background:${hero.cardBg};`}>
          <div class="sidebar-cta-title">{t('apiModel.compareAllModelsTitle')}</div>
          <p class="sidebar-cta-body">{t('apiModel.compareAllModelsBody')}</p>
          <a href={`/${lang}/api-compare`} class="sidebar-cta-btn">
            {t('apiModel.viewAllModelsBtn')}
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <!-- Also Compare -->
        <div class="sidebar-card sidebar-card-tight">
          <div class="also-compare-title">{t('apiModel.alsoCompareTitle')}</div>
          <div style="display:flex;flex-direction:column;gap:.5rem;">
            {alsoCompare.map(m => (
              <a
                href={m.path}
                class="also-compare-link"
                style={`color:${ALSO_COMPARE_COLOR[modelSlug][m.slug]};`}
                onmouseover="this.style.gap='.625rem'"
                onmouseout="this.style.gap='.375rem'">
                {t(`apiModel.${m.guideKey}`)}
                <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            ))}
          </div>
        </div>

      </aside>

    </div>
  </section>

</BaseLayout>

<style>
  /* ─── Article body — matches archive .article-body ─── */
  .article-body :global(h2) {
    font-family: 'Kanit', sans-serif;
    font-size: 1.4rem;
    font-weight: 800;
    color: #1C1C1C;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(97,85,241,0.1);
  }
  .article-body :global(h2:first-child) {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }
  .article-body :global(h3) {
    font-family: 'Kanit', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: #1C1C1C;
    letter-spacing: -0.02em;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .article-body :global(p) {
    font-size: 0.95rem;
    line-height: 1.85;
    color: #444;
    margin-bottom: 1rem;
  }
  .article-body :global(ul),
  .article-body :global(ol) {
    padding-left: 1.375rem;
    margin-bottom: 1rem;
  }
  .article-body :global(li) {
    font-size: 0.95rem;
    line-height: 1.8;
    color: #444;
    margin-bottom: 0.3rem;
  }
  .article-body :global(li:last-child) { margin-bottom: 0; }
  .article-body :global(strong) {
    color: #1C1C1C;
    font-weight: 700;
  }
  .article-body :global(a) {
    color: #6155F1;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .article-body :global(a:hover) { color: #4e44d4; }

  /* ─── FAQ (inline within article body) ─── */
  .faq-wrap { border-top: 1px solid rgba(97,85,241,0.1); margin-top: 0.75rem; }
  .faq-row { border-bottom: 1px solid rgba(97,85,241,0.08); }
  .faq-row.is-last { border-bottom: none; }
  .faq-q {
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    cursor: pointer;
    padding: 1.125rem 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.925rem;
    font-weight: 600;
    color: #1C1C1C;
    transition: color 0.18s ease;
  }
  .faq-q:hover { color: #6155F1; }
  .faq-q:focus-visible { outline: 2px solid #6155F1; outline-offset: 2px; }
  .faq-chevron { transition: transform 0.3s cubic-bezier(.22,1,.36,1); flex-shrink: 0; }
  .faq-chevron.open { transform: rotate(180deg); }
  .faq-answer { display: none; }
  .faq-answer.open { display: block; animation: faqReveal 0.22s cubic-bezier(.22,1,.36,1) both; }
  @keyframes faqReveal { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: translateY(0); } }
  .faq-answer-body :global(p) {
    padding-bottom: 1.125rem;
    font-size: 0.9rem;
    line-height: 1.8;
    color: #555;
    margin-bottom: 0;
  }
  .faq-answer-body :global(a) {
    color: #6155F1;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .faq-answer-body :global(strong) { color: #1C1C1C; font-weight: 700; }

  /* ─── Sidebar ─── */
  .post-sidebar {
    position: sticky;
    top: 88px;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .sidebar-card {
    background: #fff;
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 2px 10px rgba(97,85,241,0.08);
  }
  .sidebar-card-tight { padding: 1.375rem; }
  .sidebar-card-title {
    font-family: 'Kanit', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    color: #6155F1;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .sidebar-link {
    display: block;
    padding: 0.45rem 0.875rem;
    border-radius: 7px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.845rem;
    font-weight: 500;
    color: #666;
    text-decoration: none;
    transition: background-color 0.15s ease, color 0.15s ease;
  }
  .sidebar-link:hover { background: #F5F2FF; color: #6155F1; }
  .sidebar-link.active { background: #E2DFFE; color: #6155F1; font-weight: 600; }
  .sidebar-link:focus-visible { outline: 2px solid #6155F1; outline-offset: 2px; }

  .sidebar-cta {
    border-radius: 16px;
    padding: 1.5rem;
    color: #fff;
  }
  .sidebar-cta-title {
    font-family: 'Kanit', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .sidebar-cta-body {
    font-size: 0.825rem;
    opacity: 0.88;
    line-height: 1.6;
    margin-bottom: 1.125rem;
  }
  .sidebar-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    background: rgba(255,255,255,0.2);
    border: 1px solid rgba(255,255,255,0.35);
    color: #fff;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.825rem;
    font-weight: 600;
    padding: 0.5rem 1rem;
    border-radius: 12px;
    text-decoration: none;
    transition: background-color 0.18s ease, transform 0.18s cubic-bezier(.22,1,.36,1);
  }
  .sidebar-cta-btn:hover { background: rgba(255,255,255,0.3); transform: translateY(-1px); }
  .sidebar-cta-btn:focus-visible { outline: 2px solid #fff; outline-offset: 2px; }
  .sidebar-cta-btn:active { transform: translateY(0); }

  .also-compare-title {
    font-family: 'Kanit', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    color: #3C315B;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .also-compare-link {
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    transition: gap 0.18s ease;
  }

  /* ─── Reveal animation ─── */
  .reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.55s cubic-bezier(.22,1,.36,1), transform 0.55s cubic-bezier(.22,1,.36,1); }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* ─── Responsive: stack at 1060px (matches archive) ─── */
  @media (max-width: 1060px) {
    .post-layout { grid-template-columns: 1fr !important; }
    .post-sidebar { display: none !important; }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1 !important; transform: none !important; transition: none !important; }
    .faq-answer.open { animation: none; }
  }
</style>

<script is:inline>
  /* Reveal animation */
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

  /* FAQ accordion */
  window.toggleFaq = function(btn) {
    var answer = btn.nextElementSibling;
    var chevron = btn.querySelector('.faq-chevron');
    var isOpen = answer.classList.contains('open');
    document.querySelectorAll('.faq-answer').forEach(function(a) { a.classList.remove('open'); });
    document.querySelectorAll('.faq-chevron').forEach(function(c) { c.classList.remove('open'); });
    if (!isOpen) {
      answer.classList.add('open');
      if (chevron) chevron.classList.add('open');
    }
  };

  /* TOC scroll-spy */
  (function() {
    var sections = document.querySelectorAll('.article-body h2[id]');
    var tocLinks = document.querySelectorAll('#toc-nav .sidebar-link');
    if (!sections.length || !tocLinks.length) return;
    var spy = new IntersectionObserver(function(entries) {
      entries.forEach(function(x) {
        if (x.isIntersecting) {
          tocLinks.forEach(function(l) { l.classList.remove('active'); });
          var match = document.querySelector('#toc-nav .sidebar-link[href="#' + x.target.id + '"]');
          if (match) match.classList.add('active');
        }
      });
    }, { rootMargin: '-20% 0px -70% 0px' });
    sections.forEach(function(s) { spy.observe(s); });
  })();
</script>
