# Credentials for the data-fetch scripts (studio/scripts/fetch-*.mjs).
# Copy this file to `studio/.env`, fill in real values, and place the secret
# files under `studio/secrets/`. Both `.env` and `secrets/` are gitignored.
#
# Real values come from Antonio (1Password / onetimesecret) — never paste
# secret values into this template.

# ── GA4 (service account: read-only Viewer on the GA4 property) ────────────
GA4_PROPERTY_ID=539617761
# Path (relative to studio/) to the downloaded service-account JSON key file.
GOOGLE_SERVICE_ACCOUNT_KEYFILE=./secrets/ga4-service-account.json

# ── GSC (OAuth — Levinson is Owner; no service account) ───────────────────
# Domain property uses the sc-domain: form.
GSC_SITE_URL=sc-domain:aitoken.global
# Desktop OAuth client JSON (from Antonio) and the refresh-token file that
# fetch-gsc.mjs mints on first run.
GOOGLE_OAUTH_CLIENT=./secrets/oauth-credentials.json
GOOGLE_OAUTH_TOKEN=./secrets/gsc-oauth-token.json

# ── Cloudflare (Web Analytics — Account Analytics read scope) ─────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=96d690116e92a5de014189ece0fd30bd
